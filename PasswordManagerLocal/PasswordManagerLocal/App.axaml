<?xml version="1.0" encoding="utf-8"?>
<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="PasswordManagerLocal.App">

  <Application.Styles>
    <fluent:FluentTheme />

    <Style Selector="Border.card">
      <Setter Property="Padding" Value="20" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="#11808080" />
      <Setter Property="BorderBrush" Value="#33808080" />
    </Style>

    <Style Selector="Border.divider">
      <Setter Property="Height" Value="1" />
      <Setter Property="Background" Value="#33808080" />
    </Style>

    <Style Selector="Border.dangerZone">
      <Setter Property="BorderBrush" Value="#66D13438" />
      <Setter Property="Background" Value="#14D13438" />
    </Style>

    <Style Selector="Button.primary">
      <Setter Property="MinHeight" Value="42" />
      <Setter Property="Padding" Value="18,10" />
      <Setter Property="Background" Value="#FF2D6AE3" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.ghost">
      <Setter Property="MinHeight" Value="40" />
      <Setter Property="Padding" Value="14,10" />
    </Style>

    <Style Selector="Button.danger">
      <Setter Property="MinHeight" Value="40" />
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="Background" Value="#FFD13438" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.iconButton">
      <Setter Property="MinWidth" Value="44" />
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="Padding" Value="10" />
      <Setter Property="FontSize" Value="18" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.toolbarGroup">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="#08808080" />
      <Setter Property="BorderBrush" Value="#33808080" />
    </Style>

    <Style Selector="TextBlock.pageTitle">
      <Setter Property="FontSize" Value="28" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.subtleText">
      <Setter Property="Opacity" Value="0.78" />
    </Style>

    <Style Selector="TextBlock.errorText">
      <Setter Property="Foreground" Value="#FFD13438" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
  </Application.Styles>
</Application>
