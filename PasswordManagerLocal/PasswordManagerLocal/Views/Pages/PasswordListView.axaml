<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PasswordManagerLocal.Views.Pages.PasswordListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:PasswordManagerLocal.ViewModels.Pages"
    x:DataType="vm:PasswordsViewModel">

  <UserControl.KeyBindings>
    <KeyBinding Gesture="Enter" Command="{Binding ExecutePrimaryActionCommand}" />
  </UserControl.KeyBindings>

  <Grid>
    <ScrollViewer>
      <StackPanel Margin="16,8,16,16" Spacing="12" MaxWidth="1080" HorizontalAlignment="Stretch">
        <Border Classes="card" IsVisible="{Binding IsListPaneVisible}">
          <WrapPanel Orientation="Horizontal">
            <Border Classes="toolbarGroup" Margin="0,0,8,8">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" MinWidth="240" MaxWidth="420">
                <TextBlock Text="🔍"
                           VerticalAlignment="Center"
                           FontSize="16"
                           ToolTip.Tip="{Binding SearchLabel}" />
                <TextBox Grid.Column="1"
                         Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="{Binding SearchPlaceholder}"
                         MinWidth="180">
                  <TextBox.KeyBindings>
                    <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}" />
                  </TextBox.KeyBindings>
                </TextBox>
              </Grid>
            </Border>

            <Border Classes="toolbarGroup" Margin="0,0,8,8">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" MinWidth="210">
                <TextBlock Text="⇅"
                           VerticalAlignment="Center"
                           FontSize="18"
                           ToolTip.Tip="{Binding SortLabel}" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding SortOptions}"
                          SelectedItem="{Binding SelectedSortOption}"
                          MinWidth="170">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:PasswordSortOptionViewModel">
                      <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </Grid>
            </Border>

            <Button Classes="primary iconButton"
                    Margin="0,0,0,8"
                    Command="{Binding BeginCreatePasswordCommand}"
                    Content="{Binding AddPasswordIconLabel}"
                    ToolTip.Tip="{Binding AddPasswordButtonLabel}" />
          </WrapPanel>
        </Border>

        <Border Classes="card" IsVisible="{Binding HasStatusMessage}">
          <TextBlock Text="{Binding StatusMessage}"
                     Classes="subtleText"
                     TextWrapping="Wrap" />
        </Border>

        <StackPanel Spacing="12" IsVisible="{Binding IsListPaneVisible}">
          <Border Classes="card" IsVisible="{Binding IsVaultEmpty}">
            <StackPanel Spacing="14" HorizontalAlignment="Center" MaxWidth="520">
              <TextBlock Text="＋" FontSize="48" HorizontalAlignment="Center" />
              <TextBlock Text="{Binding EmptyStateTitle}" Classes="sectionTitle" TextAlignment="Center" TextWrapping="Wrap" />
              <TextBlock Text="{Binding EmptyStateDescription}" Classes="subtleText" TextAlignment="Center" TextWrapping="Wrap" />
              <Button Classes="primary"
                      HorizontalAlignment="Center"
                      Command="{Binding BeginCreatePasswordCommand}"
                      Content="{Binding EmptyStateAddLabel}" />
            </StackPanel>
          </Border>

          <Border Classes="card" IsVisible="{Binding IsSearchResultEmpty}">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding SearchEmptyTitle}" Classes="sectionTitle" />
              <TextBlock Text="{Binding SearchEmptyDescription}" Classes="subtleText" TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <ItemsControl ItemsSource="{Binding Passwords}"
                        IsVisible="{Binding HasPasswords}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:PasswordItemViewModel">
                <Border Margin="0,0,0,8" Padding="14" CornerRadius="16" BorderThickness="1" BorderBrush="#33808080" Background="#08808080">
                  <Grid ColumnDefinitions="8,*,Auto,Auto" ColumnSpacing="12">
                    <Border Background="{Binding ColorBrush}" CornerRadius="6" />
                    <Button Grid.Column="1"
                            Classes="ghost"
                            Command="{Binding ViewCommand}"
                            Padding="0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0">
                      <StackPanel Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{Binding ColorBrush}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DescriptionPreview}" Classes="subtleText" TextWrapping="Wrap" MaxLines="2" />
                      </StackPanel>
                    </Button>
                    <Button Grid.Column="2"
                            Classes="ghost iconButton"
                            Command="{Binding EditCommand}"
                            Content="✎" />
                    <Button Grid.Column="3"
                            Classes="danger iconButton"
                            Command="{Binding DeleteCommand}"
                            Content="🗑" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <StackPanel Spacing="12" IsVisible="{Binding IsEditorPaneVisible}">
          <Border Classes="card">
            <StackPanel Spacing="14">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Classes="ghost iconButton"
                        Command="{Binding CancelPasswordEditorCommand}"
                        Content="←"
                        ToolTip.Tip="{Binding BackToListLabel}" />
                <TextBlock Text="{Binding EditorTitle}"
                           Classes="sectionTitle"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
              </StackPanel>

              <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                  <TextBlock Text="{Binding NameLabel}" Classes="subtleText" />
                  <TextBox Text="{Binding EditorName}" Watermark="{Binding EditorNamePlaceholder}" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="8">
                  <TextBlock Text="{Binding ColorLabel}" Classes="subtleText" />
                  <ComboBox ItemsSource="{Binding PresetColors}"
                            SelectedItem="{Binding SelectedEditorColorOption}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:PasswordColorOptionViewModel">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <Border Width="18"
                                  Height="18"
                                  CornerRadius="9"
                                  BorderThickness="1"
                                  BorderBrush="#33808080"
                                  Background="{Binding Brush}" />
                          <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                        </StackPanel>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <WrapPanel Orientation="Horizontal">
                    <Border Width="28"
                            Height="28"
                            CornerRadius="14"
                            BorderThickness="1"
                            BorderBrush="#33808080"
                            Background="{Binding EditorColorBrush}"
                            Margin="0,0,8,8" />
                    <TextBlock Text="{Binding EditorColorCode}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,8" />
                    <Button Classes="ghost"
                            Command="{Binding OpenCustomColorPickerCommand}"
                            Content="{Binding MoreColorsLabel}"
                            Margin="0,0,0,8" />
                  </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="6">
                  <TextBlock Text="{Binding DescriptionLabel}" Classes="subtleText" />
                  <TextBox Text="{Binding EditorDescription}"
                           Watermark="{Binding EditorDescriptionPlaceholder}"
                           AcceptsReturn="True"
                           MinHeight="92"
                           TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="6">
                  <TextBlock Text="{Binding PasswordLabel}" Classes="subtleText" />
                  <WrapPanel Orientation="Horizontal">
                    <TextBox Text="{Binding EditorPassword}"
                             PasswordChar="{Binding EditorPasswordMaskCharacter}"
                             Watermark="{Binding EditorPasswordPlaceholder}"
                             MinWidth="240"
                             MaxWidth="520"
                             Margin="0,0,8,8" />
                    <Button Classes="ghost"
                            Command="{Binding ToggleEditorPasswordVisibilityCommand}"
                            Content="{Binding EditorPasswordVisibilityToggleText}"
                            Margin="0,0,8,8" />
                    <Button Classes="ghost"
                            Command="{Binding RevealEditorPasswordCommand}"
                            Content="{Binding RevealEditorPasswordLabel}"
                            IsVisible="{Binding CanRevealEditorStoredPassword}"
                            Margin="0,0,0,8" />
                  </WrapPanel>
                  <TextBlock Text="{Binding EditorPasswordHint}" Classes="subtleText" TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="3"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Height="32"
                        CornerRadius="14"
                        BorderThickness="1"
                        BorderBrush="#33808080"
                        Background="{Binding EditorColorBrush}" />
              </Grid>

              <WrapPanel Orientation="Horizontal">
                <Button Classes="primary"
                        Command="{Binding SavePasswordCommand}"
                        Content="{Binding SavePasswordButtonLabel}"
                        Margin="0,0,8,8" />
              </WrapPanel>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="12" IsVisible="{Binding IsColorPaneVisible}">
          <Border Classes="card">
            <StackPanel Spacing="16">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Classes="ghost iconButton"
                        Command="{Binding BackToPasswordEditorCommand}"
                        Content="←"
                        ToolTip.Tip="{Binding BackToPasswordEditorLabel}" />
                <TextBlock Text="{Binding ColorPickerTitle}"
                           Classes="sectionTitle"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
              </StackPanel>

              <TextBlock Text="{Binding ColorPickerDescription}"
                         Classes="subtleText"
                         TextWrapping="Wrap" />

              <Border Height="72"
                      CornerRadius="18"
                      BorderThickness="1"
                      BorderBrush="#33808080"
                      Background="{Binding EditorColorBrush}" />

              <StackPanel Spacing="6">
                <TextBlock Text="{Binding CurrentColorCodeLabel}" Classes="subtleText" />
                <TextBlock Text="{Binding EditorColorCode}" FontSize="18" FontWeight="SemiBold" />
              </StackPanel>

              <StackPanel Spacing="8">
                <TextBlock Text="{Binding ColorPickerCodeLabel}" Classes="subtleText" />
                <WrapPanel Orientation="Horizontal">
                  <TextBox Text="{Binding CustomColorCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           Watermark="{Binding ColorPickerCodePlaceholder}"
                           MinWidth="220"
                           MaxWidth="360"
                           Margin="0,0,8,8">
                    <TextBox.KeyBindings>
                      <KeyBinding Gesture="Enter" Command="{Binding ApplyManualColorCodeCommand}" />
                    </TextBox.KeyBindings>
                  </TextBox>
                  <Button Classes="primary"
                          Command="{Binding ApplyManualColorCodeCommand}"
                          Content="{Binding ApplyColorCodeLabel}"
                          Margin="0,0,0,8" />
                </WrapPanel>
              </StackPanel>

              <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
                <Grid Grid.Row="0" ColumnDefinitions="80,*,48" ColumnSpacing="10">
                  <TextBlock Text="{Binding AlphaLabel}" Classes="subtleText" VerticalAlignment="Center" />
                  <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding CustomAlpha, Mode=TwoWay}" />
                  <TextBlock Grid.Column="2" Text="{Binding CustomAlphaText}" VerticalAlignment="Center" TextAlignment="Right" />
                </Grid>
                <Grid Grid.Row="1" ColumnDefinitions="80,*,48" ColumnSpacing="10">
                  <TextBlock Text="{Binding RedLabel}" Classes="subtleText" VerticalAlignment="Center" />
                  <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding CustomRed, Mode=TwoWay}" />
                  <TextBlock Grid.Column="2" Text="{Binding CustomRedText}" VerticalAlignment="Center" TextAlignment="Right" />
                </Grid>
                <Grid Grid.Row="2" ColumnDefinitions="80,*,48" ColumnSpacing="10">
                  <TextBlock Text="{Binding GreenLabel}" Classes="subtleText" VerticalAlignment="Center" />
                  <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding CustomGreen, Mode=TwoWay}" />
                  <TextBlock Grid.Column="2" Text="{Binding CustomGreenText}" VerticalAlignment="Center" TextAlignment="Right" />
                </Grid>
                <Grid Grid.Row="3" ColumnDefinitions="80,*,48" ColumnSpacing="10">
                  <TextBlock Text="{Binding BlueLabel}" Classes="subtleText" VerticalAlignment="Center" />
                  <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding CustomBlue, Mode=TwoWay}" />
                  <TextBlock Grid.Column="2" Text="{Binding CustomBlueText}" VerticalAlignment="Center" TextAlignment="Right" />
                </Grid>
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Spacing="12" IsVisible="{Binding IsDetailsPaneVisible}">
          <Border Classes="card" IsVisible="{Binding HasSelection}">
            <StackPanel Spacing="14">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Classes="ghost iconButton"
                        Command="{Binding BackToListCommand}"
                        Content="←"
                        ToolTip.Tip="{Binding BackToListLabel}" />
                <TextBlock Text="{Binding SelectedPassword.Name}"
                           Classes="sectionTitle"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{Binding SelectedPassword.ColorBrush}" />
              </StackPanel>

              <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                  <TextBlock Text="{Binding NameLabel}" Classes="subtleText" />
                  <TextBlock Text="{Binding SelectedPassword.Name}" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                  <TextBlock Text="{Binding ColorLabel}" Classes="subtleText" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Width="20" Height="20" CornerRadius="10" Background="{Binding SelectedPassword.ColorBrush}" />
                    <TextBlock Text="{Binding SelectedPassword.Color}" VerticalAlignment="Center" />
                  </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                  <TextBlock Text="{Binding DescriptionLabel}" Classes="subtleText" />
                  <TextBlock Text="{Binding SelectedPassword.DescriptionPreview}" TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" ColumnDefinitions="*,*" ColumnSpacing="12">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding CreatedAtLabel}" Classes="subtleText" />
                    <TextBlock Text="{Binding SelectedPassword.CreatedAtText}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="{Binding UpdatedAtLabel}" Classes="subtleText" />
                    <TextBlock Text="{Binding SelectedPassword.LastUpdatedAtText}" />
                  </StackPanel>
                </Grid>
              </Grid>

              <StackPanel Spacing="6">
                <TextBlock Text="{Binding PasswordLabel}" Classes="subtleText" />

                <Border Classes="card" IsVisible="{Binding IsPasswordHidden}">
                  <TextBlock Text="{Binding PasswordRevealHint}" Classes="subtleText" TextWrapping="Wrap" />
                </Border>

                <TextBox Text="{Binding RevealedPassword, Mode=OneWay}"
                         IsVisible="{Binding HasRevealedPassword}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap" />

                <WrapPanel Orientation="Horizontal">
                  <Button Classes="ghost"
                          Command="{Binding RevealPasswordCommand}"
                          Content="{Binding RevealPasswordLabel}"
                          Margin="0,0,8,8" />
                  <Button Classes="ghost"
                          Command="{Binding HidePasswordCommand}"
                          Content="{Binding HidePasswordLabel}"
                          IsVisible="{Binding HasRevealedPassword}"
                          Margin="0,0,8,8" />
                  <Button Classes="ghost"
                          Command="{Binding EditSelectedPasswordCommand}"
                          Content="✎"
                          ToolTip.Tip="{Binding EditPasswordLabel}"
                          Margin="0,0,8,8" />
                  <Button Classes="danger"
                          Command="{Binding BeginDeleteSelectedPasswordCommand}"
                          Content="🗑"
                          ToolTip.Tip="{Binding DeletePasswordLabel}"
                          Margin="0,0,0,8" />
                </WrapPanel>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

    <Border Background="#99000000" IsVisible="{Binding IsDeleteConfirmationOpen}">
      <Border Classes="card" MaxWidth="460" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
        <StackPanel Spacing="14">
          <TextBlock Text="{Binding DeleteConfirmationTitle}" Classes="sectionTitle" TextWrapping="Wrap" />
          <TextBlock Text="{Binding DeleteConfirmationMessage}" TextWrapping="Wrap" />
          <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Classes="ghost"
                    Command="{Binding CancelDeletePasswordCommand}"
                    Content="{Binding CancelButtonLabel}"
                    Margin="0,0,8,8" />
            <Button Classes="danger"
                    Command="{Binding ConfirmDeletePasswordCommand}"
                    Content="{Binding ConfirmDeletePasswordLabel}"
                    Margin="0,0,0,8" />
          </WrapPanel>
        </StackPanel>
      </Border>
    </Border>
  </Grid>
</UserControl>
