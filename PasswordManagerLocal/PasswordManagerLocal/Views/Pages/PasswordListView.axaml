<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PasswordManagerLocal.Views.Pages.PasswordListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:PasswordManagerLocal.ViewModels.Pages"
    x:DataType="vm:PasswordsViewModel">

  <ScrollViewer>
    <StackPanel Margin="16,8,16,16" Spacing="12">
      <Border Classes="card">
        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding Title}" Classes="pageTitle" />
            <TextBlock Text="{Binding Subtitle}" Classes="subtleText" TextWrapping="Wrap" />
            <TextBlock Text="{Binding StatusMessage}" Classes="subtleText" IsVisible="{Binding HasStatusMessage}" TextWrapping="Wrap" />
          </StackPanel>

          <Button Grid.Column="1"
                  Classes="ghost"
                  Command="{Binding RefreshCommand}"
                  Content="{Binding RefreshButtonLabel}" />
          <Button Grid.Column="2"
                  Classes="primary"
                  Command="{Binding BeginCreatePasswordCommand}"
                  Content="{Binding AddPasswordButtonLabel}" />
        </Grid>
      </Border>

      <Border Classes="card" IsVisible="{Binding IsEditorOpen}">
        <StackPanel Spacing="12">
          <TextBlock Text="{Binding EditorTitle}" Classes="sectionTitle" />

          <StackPanel Spacing="6">
            <TextBlock Text="{Binding NameLabel}" />
            <TextBox Text="{Binding EditorName}" Watermark="{Binding EditorNamePlaceholder}" />
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="{Binding DescriptionLabel}" />
            <TextBox Text="{Binding EditorDescription}"
                     Watermark="{Binding EditorDescriptionPlaceholder}"
                     AcceptsReturn="True"
                     MinHeight="96"
                     TextWrapping="Wrap" />
          </StackPanel>

          <Grid ColumnDefinitions="*,120" ColumnSpacing="12">
            <StackPanel Spacing="6">
              <TextBlock Text="{Binding ColorLabel}" />
              <TextBox Text="{Binding EditorColor}" Watermark="{Binding EditorColorPlaceholder}" />
            </StackPanel>
            <Border Grid.Column="1"
                    CornerRadius="12"
                    BorderThickness="1"
                    BorderBrush="#33808080"
                    Background="{Binding EditorColorBrush}" />
          </Grid>

          <StackPanel Spacing="6">
            <TextBlock Text="{Binding PasswordLabel}" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox Grid.Column="0"
                       Text="{Binding EditorPassword}"
                       PasswordChar="{Binding EditorPasswordMaskCharacter}"
                       Watermark="{Binding EditorPasswordPlaceholder}" />
              <Button Grid.Column="1"
                      Classes="ghost"
                      Command="{Binding ToggleEditorPasswordVisibilityCommand}"
                      Content="{Binding EditorPasswordVisibilityToggleText}" />
            </Grid>
            <TextBlock Text="{Binding EditorPasswordHint}" Classes="subtleText" TextWrapping="Wrap" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="primary"
                    Command="{Binding SavePasswordCommand}"
                    Content="{Binding SavePasswordButtonLabel}" />
            <Button Classes="ghost"
                    Command="{Binding CancelPasswordEditorCommand}"
                    Content="{Binding CancelButtonLabel}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="card" IsVisible="{Binding IsEmpty}">
        <StackPanel Spacing="8">
          <TextBlock Text="{Binding EmptyStateTitle}" Classes="sectionTitle" />
          <TextBlock Text="{Binding EmptyStateDescription}" Classes="subtleText" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Classes="card" IsVisible="{Binding HasPasswords}">
        <StackPanel Spacing="10">
          <TextBlock Text="{Binding DetailsTitle}" Classes="sectionTitle" />

          <ListBox ItemsSource="{Binding Passwords}"
                   SelectedItem="{Binding SelectedPassword}"
                   BorderThickness="0"
                   Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:PasswordItemViewModel">
                <Border Margin="0,0,0,8" Padding="12" CornerRadius="14" BorderThickness="1" BorderBrush="#33808080">
                  <Grid ColumnDefinitions="8,*,Auto" ColumnSpacing="12">
                    <Border Background="{Binding ColorBrush}" CornerRadius="6" />
                    <StackPanel Grid.Column="1" Spacing="4">
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding DescriptionPreview}" Classes="subtleText" TextWrapping="Wrap" MaxLines="2" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                      <Button Classes="ghost" Command="{Binding EditCommand}" Content="✎" />
                      <Button Classes="danger" Command="{Binding DeleteCommand}" Content="🗑" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Border>

      <Border Classes="card" IsVisible="{Binding HasSelection}">
        <StackPanel Spacing="12">
          <TextBlock Text="{Binding SelectedPassword.Name}" Classes="sectionTitle" TextWrapping="Wrap" />

          <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding NameLabel}" Classes="subtleText" />
              <TextBlock Text="{Binding SelectedPassword.Name}" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="4">
              <TextBlock Text="{Binding ColorLabel}" Classes="subtleText" />
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Width="20" Height="20" CornerRadius="10" Background="{Binding SelectedPassword.ColorBrush}" />
                <TextBlock Text="{Binding SelectedPassword.Color}" VerticalAlignment="Center" />
              </StackPanel>
            </StackPanel>
          </Grid>

          <StackPanel Spacing="4">
            <TextBlock Text="{Binding DescriptionLabel}" Classes="subtleText" />
            <TextBlock Text="{Binding SelectedPassword.DescriptionPreview}" TextWrapping="Wrap" />
          </StackPanel>

          <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding CreatedAtLabel}" Classes="subtleText" />
              <TextBlock Text="{Binding SelectedPassword.CreatedAtText}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="4">
              <TextBlock Text="{Binding UpdatedAtLabel}" Classes="subtleText" />
              <TextBlock Text="{Binding SelectedPassword.LastUpdatedAtText}" />
            </StackPanel>
          </Grid>

          <StackPanel Spacing="6">
            <TextBlock Text="{Binding PasswordLabel}" Classes="subtleText" />
            <TextBox Text="{Binding PasswordDisplayValue, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Classes="ghost"
                      Command="{Binding RevealPasswordCommand}"
                      Content="{Binding RevealPasswordLabel}" />
              <Button Classes="ghost"
                      Command="{Binding HidePasswordCommand}"
                      Content="{Binding HidePasswordLabel}" />
              <Button Classes="ghost"
                      Command="{Binding EditSelectedPasswordCommand}"
                      Content="{Binding EditPasswordLabel}" />
              <Button Classes="danger"
                      Command="{Binding DeleteSelectedPasswordCommand}"
                      Content="{Binding DeletePasswordLabel}" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="card" IsVisible="{Binding IsSelectionEmpty}">
        <StackPanel Spacing="8">
          <TextBlock Text="{Binding DetailsEmptyTitle}" Classes="sectionTitle" />
          <TextBlock Text="{Binding DetailsEmptyDescription}" Classes="subtleText" TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
